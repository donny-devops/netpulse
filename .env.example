# Server
PORT=3000
NODE_ENV=development

# Authentication — change this to a strong secret
API_KEY=changeme-secret-key

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Redis (set REDIS_ENABLED=true to activate queue integration)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
